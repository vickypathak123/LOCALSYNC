PORT=3011
REDIS_URL=redis://localhost:6379
JWT_SECRET=localsync-hackathon-dev-secret
FRONTEND_URL=http://localhost:3000

# Optional — leave unset to log invite emails to the console instead of sending them.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=LocalSync <no-reply@localsync.dev>

# Optional — leave unset to keep the dashboard's straight-line distance/ETA.
# When set, in-progress tasks get a real road route via Mapbox Directions
# (https://account.mapbox.com/access-tokens/), drawn on the map and used for
# the displayed distance/ETA. Geofence "reached" detection is unaffected either
# way — it's always the straight-line radius check.
MAPBOX_ACCESS_TOKEN=
